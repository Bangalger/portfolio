{
  "name": "portfolio",
  "private": true,
  "scripts": {
    "build:css": "tailwindcss -i ./css/tailwind-src.css -o ./css/tailwind.css --minify",
    "build:images": "node scripts/optimize-images.mjs",
    "build": "npm run build:css && npm run build:images",
    "watch:css": "tailwindcss -i ./css/tailwind-src.css -o ./css/tailwind.css --watch"
  },
  "devDependencies": {
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.10",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "sharp": "^0.34.1",
    "tailwindcss": "^3.4.17"
  }
}
